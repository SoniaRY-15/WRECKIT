{
    "manifest_version": 3,
    "name": "Buzzer Detector",
    "version": "1.0.0",

    "action": {
        "default_popup": "index.html",
        "default_title": "Buzzer Detector"
    },

    "permissions": [
        "activeTab",
        "storage"
    ],

    "host_permissions": [
        "<all_urls>"
    ],

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["assets/content.js"]
        }
    ]
}